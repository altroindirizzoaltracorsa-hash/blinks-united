# ── Spotify ───────────────────────────────────────────────────────────────────
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Spotify track IDs for the three campaign songs
# Get them from the track URL: open.spotify.com/track/TRACK_ID_HERE
SPOTIFY_TRACK_JUMP=
SPOTIFY_TRACK_SHUTDOWN=
SPOTIFY_TRACK_DDUDUDU=

# Optional: your Spotify sp_dc cookie for more reliable play counts.
# Browser DevTools → Application → Cookies → open.spotify.com → sp_dc
# Without this, the API still works but may fall back to HTML scraping.
SPOTIFY_SP_DC=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Cron protection ───────────────────────────────────────────────────────────
# Set this to any random secret string; include it as a Bearer token when
# calling /api/spotify/refresh manually or via Vercel Cron.
CRON_SECRET=your_random_secret_here
